<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="600.0" minWidth="900.0" 
            styleClass="main-container" stylesheets="@style.css" 
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="es.um.tds.gestionGastos.interfaz.VentanaPrincipalController">		<!-- Contrololador con la lógica de la UI -->
   
   <top>
      <VBox spacing="0">
         <children>
            <HBox alignment="CENTER_LEFT" styleClass="header-banner" spacing="20">
               <padding>
                  <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
               </padding>
               <children>
                  <Label text="App Gestion de Gastos" textFill="WHITE">		<!-- TITULO DE LA APLICACION -->
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Label>
                  <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE" styleClass="main-tabs">
                    <tabs>
                      <Tab text="Dashboard" />
                      <Tab text="Mis Gastos" />
                      <Tab text="Gastos Compartidos" />
                      <Tab fx:id="tabAlertas" text="Alertas" />
                    </tabs>
                  </TabPane>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" styleClass="button-add" text="+ Nuevo Gasto" />
               </children>
            </HBox>
            
            <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="filter-bar">
               <padding>
                  <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
               </padding>
               <children>
                  <DatePicker promptText="Fecha" styleClass="dark-datepicker" />
                  <ComboBox prefWidth="150.0" promptText="Categoría" styleClass="dark-combo" />
                  <ComboBox prefWidth="150.0" promptText="Método Pago" styleClass="dark-combo" />
                  <Button mnemonicParsing="false" styleClass="button-filter" text="Filtrar" />
               </children>
            </HBox>
         </children>
      </VBox>
   </top>

	<center>
   <StackPane fx:id="contentArea">
      <children>
         <AnchorPane>
            <children>
               <VBox styleClass="card-container" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="10.0">
                  <children>
                     <TableView fx:id="tablaGastos" VBox.vgrow="ALWAYS" styleClass="modern-table">
                        <columns>
                           <TableColumn prefWidth="120.0" text="Fecha" />
                           <TableColumn prefWidth="250.0" text="Descripción" />
                           <TableColumn prefWidth="150.0" text="Categoría" />
                           <TableColumn prefWidth="120.0" text="Usuario" />
                           <TableColumn prefWidth="120.0" text="Monto" />
                        </columns>
                        <columnResizePolicy>
                           <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                     </TableView>
                  </children>
               </VBox>
            </children>
         </AnchorPane>
      </children>
   </StackPane>
</center>
	
   <bottom>
      <HBox alignment="CENTER_RIGHT" spacing="20.0" styleClass="status-bar">
         <padding>
            <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
         </padding>
         <children>
            <Label text="Total Filtrado:" textFill="#b2b2b2" />
            <Label styleClass="label-total" text="€ 1,240.50" />
         </children>
      </HBox>
   </bottom>
</BorderPane>