<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<ScrollPane fitToWidth="true" styleClass="transparent-scroll" stylesheets="@base_style.css, @dashboard_style.css" 
			xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="es.um.tds.gestionGastos.Controladores.ControladorDashboard">
   <content>
      <VBox spacing="25.0">
         <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </padding>
         <children>
            <HBox spacing="20.0">
               <children>
                  <VBox styleClass="summary-card" HBox.hgrow="ALWAYS">
                     <children>
                        <Label styleClass="summary-label" text="Gasto Total Mes" />
                        <Label styleClass="summary-value" text="1.450,20 €" />	<!-- Gasto total en el mes -->
                     </children>
                  </VBox>
                  <VBox styleClass="summary-card" HBox.hgrow="ALWAYS">
                     <children>
                        <Label styleClass="summary-label" text="Promedio Diario" />
                        <Label styleClass="summary-value" text="48,34 €" />	<!-- Gasto promedio diario -->
                     </children>
                  </VBox>
                  <VBox styleClass="summary-card" HBox.hgrow="ALWAYS">
                     <children>
                        <Label styleClass="summary-label" text="Categoría Top" />
                        <Label styleClass="summary-value, text-positive" text="Alimentación" />	<!-- Categoría con mas gasto -->
                     </children>
                  </VBox>
               </children>
            </HBox>

            <GridPane hgap="20.0" vgap="20.0">
              <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="400.0" prefHeight="400.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
                  <VBox styleClass="card-container" GridPane.columnIndex="0">
                     <children>
                        <Label styleClass="card-title" text="Distribución por Categoría">
                           <padding><Insets bottom="10" left="15" top="15"/></padding>
                        </Label>
                        <PieChart fx:id="pieChartGastos" legendSide="BOTTOM" VBox.vgrow="ALWAYS" />	<!-- Pie chart -->
                     </children>
                  </VBox>

                  <VBox styleClass="card-container" GridPane.columnIndex="1">
                     <children>
                        <Label styleClass="card-title" text="Gastos Semanales">
                           <padding><Insets bottom="10" left="15" top="15"/></padding>
                        </Label>
                        <BarChart fx:id="barChartGastos" VBox.vgrow="ALWAYS">	<!-- Bar chart semanal -->
                          <xAxis>
                            <CategoryAxis side="BOTTOM" />
                          </xAxis>
                          <yAxis>
                            <NumberAxis side="LEFT" />
                          </yAxis>
                        </BarChart>
                     </children>
                  </VBox>
               </children>
            </GridPane>
         </children>
      </VBox>
   </content>
</ScrollPane>