<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20.0" styleClass="dialog-container" stylesheets="@base_style.css, @modal_formulario_style.css"
		xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
		fx:controller="es.um.tds.gestionGastos.interfaz.AgregarAlertaController">
   <padding>
      <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
   </padding>
   <children>
      <HBox alignment="CENTER_LEFT">
         <children>
            <Label styleClass="dialog-title" text="Configurar Nueva Alerta" />
            <Region HBox.hgrow="ALWAYS" />
         </children>
      </HBox>

      <Separator styleClass="dark-separator" />

      <VBox spacing="15.0">
         <children>
            <VBox spacing="5.0">
               <children>
                  <Label styleClass="form-label" text="Periodo de la Alerta" />
                  <HBox spacing="10.0">
                     <children>
                        <RadioButton mnemonicParsing="false" selected="true" text="Semanal" textFill="WHITE">
                           <toggleGroup>
                              <ToggleGroup fx:id="periodoGroup" />	<!-- Tipo de alerta: Semanal o Mensual (periodoGroup) -->
                           </toggleGroup>
                        </RadioButton>
                        <RadioButton mnemonicParsing="false" text="Mensual" textFill="WHITE" toggleGroup="$periodoGroup" />
                     </children>
                  </HBox>
               </children>
            </VBox>

            <VBox spacing="5.0">
               <children>
                  <Label styleClass="form-label" text="Categoría (Opcional)" />
                  <ComboBox fx:id="comboCategoriaAlerta" maxWidth="Infinity" promptText="Todas las categorías" styleClass="dark-input" />	<!-- Categoria (comboCategoriaAlerta) -->
               </children>
            </VBox>

            <VBox spacing="5.0">
               <children>
                  <Label styleClass="form-label" text="Límite Máximo de Gasto (€)" />
                  <TextField fx:id="txtLimite" promptText="Ej: 500" styleClass="dark-input, amount-input" />	<!-- Limite (txtLimite) -->
               </children>
            </VBox>
         </children>
      </VBox>

      <HBox alignment="CENTER_RIGHT" spacing="12.0">
         <children>
            <Button mnemonicParsing="false" styleClass="button-secondary" text="Cancelar" onAction="#cancelar"/>
            <Button mnemonicParsing="false" styleClass="button-primary" text="Activar Alerta" onAction="#activarAlerta"/>
         </children>
      </HBox>
   </children>
</VBox>