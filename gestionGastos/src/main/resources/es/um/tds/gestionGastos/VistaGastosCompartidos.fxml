<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" styleClass="dialog-container" stylesheets="@base_style.css, @tabla_style.css, @gasto_compartido_style.css"
		xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
		fx:controller="es.um.tds.gestionGastos.interfaz.CuentaCompartidaController">
	<padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
    
    
    <HBox spacing="15" alignment="CENTER_LEFT">
        <Label text="Resumen de Saldos" styleClass="section-title"/>
        <ComboBox fx:id="comboCuentas" promptText="Seleccionar cuenta..." prefWidth="200" styleClass="combo-box-modern"/>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="Configurar Cuenta / Porcentajes" styleClass="button-action-ghost"/>
    </HBox>

    <HBox spacing="20" fx:id="balancesContainer" minHeight="100">
        </HBox>

    <VBox styleClass="card-container" VBox.vgrow="ALWAYS">
        <TableView fx:id="tablaGastosCuenta" styleClass="modern-table" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colFecha" text="Fecha" prefWidth="100"/>
                <TableColumn fx:id="colDescripcion" text="Descripción" prefWidth="200"/>
                <TableColumn fx:id="colPagador" text="Pagado por" prefWidth="120"/>
                <TableColumn fx:id="colCategoria" text="Categoría" prefWidth="120"/>
                <TableColumn fx:id="colMonto" text="Total" prefWidth="100"/>
            </columns>
             <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
             </columnResizePolicy>
        </TableView>
    </VBox>
</VBox>